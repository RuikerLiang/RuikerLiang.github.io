---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import SectionTitle from '@/components/SectionTitle.astro';
import ProfileHero from '@/components/ProfileHero.astro';
import ResearchCard from '@/components/ResearchCard.astro';
import ProjectCard from '@/components/ProjectCard.astro';
import { profile, education, awards, researchInterests, skills, motivation } from '@/data/profile';
import { projects } from '@/data/projects';
---

<Layout
  title="Kerui Zhang | Home"
  description="Personal homepage of Kerui Zhang, a Class of 2023 ZJUI ECE undergraduate student."
  path="/"
>
  <Navbar />
  <main>
    <div id="top"></div>
    <ProfileHero />

    <section id="about" class="section-space" aria-labelledby="bio-title">
      <div class="container-page" data-reveal>
        <SectionTitle title="About" subtitle="A single-page overview of my background, honors, and project experience." />
        <div class="grid gap-4 lg:grid-cols-[1.5fr_1fr]">
          <div class="card-base">
            <p class="text-sm leading-7 text-slate-600 sm:text-base">{profile.bio}</p>
            <p class="mt-4 text-sm leading-7 text-slate-600 sm:text-base">{motivation}</p>
          </div>
          <div class="card-base">
            <h3 class="text-base font-semibold text-slate-900">Quick Snapshot</h3>
            <dl class="mt-4 space-y-3 text-sm text-slate-600">
              <div>
                <dt class="font-medium text-slate-800">Name</dt>
                <dd class="mt-1">{profile.name}</dd>
              </div>
              <div>
                <dt class="font-medium text-slate-800">Program</dt>
                <dd class="mt-1">Electrical and Computer Engineering</dd>
              </div>
              <div>
                <dt class="font-medium text-slate-800">Cohort</dt>
                <dd class="mt-1">2023</dd>
              </div>
              <div>
                <dt class="font-medium text-slate-800">Location</dt>
                <dd class="mt-1">{profile.location}</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    <section id="background" class="section-space" aria-labelledby="background-title">
      <div class="container-page">
        <SectionTitle title="Background" subtitle="Education and recognition at a glance." />
        <div class="grid gap-4 lg:grid-cols-2">
          <div class="space-y-4">
            {education.map((item) => (
              <article class="card-base" data-reveal>
                <h3 class="text-base font-semibold text-slate-900">{item.degree}</h3>
                <p class="mt-1 text-sm text-slate-600">{item.institution}</p>
                <p class="mt-2 text-sm font-medium text-accent-700">{item.period}</p>
                {item.details && <p class="mt-3 text-sm leading-6 text-slate-600">{item.details}</p>}
              </article>
            ))}
          </div>
          <div class="space-y-4">
            {awards.map((award) => (
              <article class="card-base" data-reveal>
                <h3 class="text-base font-semibold text-slate-900">{award.title}</h3>
                {award.description && <p class="mt-3 text-sm leading-6 text-slate-600">{award.description}</p>}
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section id="focus" class="section-space" aria-labelledby="focus-title">
      <div class="container-page">
        <SectionTitle title="Technical Focus" subtitle="Areas that best reflect the systems and engineering work I enjoy most." />
        <div class="grid gap-4 sm:grid-cols-2">
          {researchInterests.map((interest) => (
            <ResearchCard {...interest} />
          ))}
        </div>
      </div>
    </section>

    <section id="projects" class="section-space" aria-labelledby="selected-projects-title">
      <div class="container-page">
        <SectionTitle title="Projects" subtitle="Representative work across backend engineering, systems programming, and robotics." />
        <div class="grid gap-4 lg:grid-cols-2">
          {projects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      </div>
    </section>

    <section id="skills" class="section-space" aria-labelledby="skills-title">
      <div class="container-page">
        <SectionTitle title="Skills" subtitle="Tools and topics that show up repeatedly across my project work." />
        <div class="card-base" data-reveal>
          <ul class="flex flex-wrap gap-2">
            {skills.map((skill) => (
              <li class="rounded-full bg-slate-100 px-3 py-1 text-sm text-slate-700">{skill}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
