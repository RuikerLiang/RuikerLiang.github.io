---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import SectionTitle from '@/components/SectionTitle.astro';
import { profile, education, skills, motivation, timeline } from '@/data/profile';
---

<Layout
  title="Kerui Zhang | About"
  description="About Kerui Zhang: background, education, skills, and research motivation."
  path="/about"
>
  <Navbar />
  <main class="section-space">
    <div class="container-page space-y-12">
      <section aria-labelledby="about-overview" data-reveal>
        <SectionTitle title="About" subtitle="Brief introduction designed for quick academic review." />
        <div class="card-base">
          <p class="text-sm leading-7 text-slate-600 sm:text-base">{profile.bio}</p>
        </div>
      </section>

      <section aria-labelledby="about-education">
        <SectionTitle title="Education" />
        <div class="space-y-4">
          {education.map((item) => (
            <article class="card-base" data-reveal>
              <h3 class="text-base font-semibold text-slate-900">{item.degree}</h3>
              <p class="mt-1 text-sm text-slate-600">{item.institution}</p>
              <p class="mt-1 text-sm font-medium text-accent-700">{item.period}</p>
              {item.details && <p class="mt-2 text-sm leading-6 text-slate-600">{item.details}</p>}
            </article>
          ))}
        </div>
      </section>

      <section aria-labelledby="about-skills">
        <SectionTitle title="Skills Overview" />
        <div class="card-base" data-reveal>
          <ul class="flex flex-wrap gap-2">
            {skills.map((skill) => (
              <li class="rounded-full bg-slate-100 px-3 py-1 text-sm text-slate-700">{skill}</li>
            ))}
          </ul>
        </div>
      </section>

      <section aria-labelledby="about-motivation" data-reveal>
        <SectionTitle title="Research Motivation" />
        <div class="card-base">
          <p class="text-sm leading-7 text-slate-600 sm:text-base">{motivation}</p>
        </div>
      </section>

      <section aria-labelledby="about-timeline">
        <SectionTitle title="Experience Timeline" subtitle="Optional timeline format for faster scanning." />
        <div class="space-y-4">
          {timeline.map((item) => (
            <article class="card-base" data-reveal>
              <div class="flex flex-wrap items-center justify-between gap-2">
                <h3 class="text-base font-semibold text-slate-900">{item.title}</h3>
                <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600">{item.period}</span>
              </div>
              <p class="mt-1 text-sm text-slate-600">{item.organization}</p>
              <p class="mt-3 text-sm leading-6 text-slate-600">{item.description}</p>
            </article>
          ))}
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
