---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import SectionTitle from '@/components/SectionTitle.astro';
import ResearchCard from '@/components/ResearchCard.astro';
import { researchInterests } from '@/data/profile';
---

<Layout
  title="Kerui Zhang | Research"
  description="Research interests of Kerui Zhang, including graphics, generative models, inverse rendering, 3D vision, and embodied AI."
  path="/research"
>
  <Navbar />
  <main class="section-space">
    <div class="container-page">
      <section aria-labelledby="research-title">
        <SectionTitle
          title="Research Interests"
          subtitle="Each direction can be expanded into a full research statement in future applications."
        />
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {researchInterests.map((interest) => (
            <ResearchCard {...interest} />
          ))}
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
