---
import Layout from '@/layouts/Layout.astro';
import Navbar from '@/components/Navbar.astro';
import Footer from '@/components/Footer.astro';
import SectionTitle from '@/components/SectionTitle.astro';
import { education, researchInterests, skills, profile } from '@/data/profile';
import { projects } from '@/data/projects';
---

<Layout title="Kerui Zhang | CV" description="Online CV overview and downloadable resume for Kerui Zhang." path="/cv">
  <Navbar />
  <main class="section-space">
    <div class="container-page space-y-10">
      <section aria-labelledby="cv-title" data-reveal>
        <SectionTitle
          title="Curriculum Vitae"
          subtitle="A concise online overview. Download the PDF version for full details."
        />
        <div class="card-base flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
          <p class="text-sm text-slate-600">Download CV (placeholder available now, replace with your final CV PDF later).</p>
          <a href={profile.cvLink} class="btn-primary" target="_blank" rel="noopener noreferrer">Download CV</a>
        </div>
      </section>

      <section aria-labelledby="cv-education">
        <SectionTitle title="Education" />
        <div class="space-y-3">
          {education.map((item) => (
            <article class="card-base" data-reveal>
              <h3 class="font-semibold text-slate-900">{item.degree}</h3>
              <p class="mt-1 text-sm text-slate-600">{item.institution}</p>
              <p class="mt-1 text-sm font-medium text-accent-700">{item.period}</p>
            </article>
          ))}
        </div>
      </section>

      <section aria-labelledby="cv-research-areas">
        <SectionTitle title="Research Areas" />
        <div class="card-base" data-reveal>
          <ul class="flex flex-wrap gap-2">
            {researchInterests.map((interest) => (
              <li class="rounded-full bg-accent-50 px-3 py-1 text-sm text-accent-700">{interest.title}</li>
            ))}
          </ul>
        </div>
      </section>

      <section aria-labelledby="cv-selected-work">
        <SectionTitle title="Selected Work" />
        <div class="space-y-3">
          {projects.slice(0, 3).map((item) => (
            <article class="card-base" data-reveal>
              <div class="flex flex-wrap items-center justify-between gap-2">
                <h3 class="font-semibold text-slate-900">{item.name}</h3>
                <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-600">{item.period}</span>
              </div>
              <p class="mt-2 text-sm leading-6 text-slate-600">{item.summary}</p>
            </article>
          ))}
        </div>
      </section>

      <section aria-labelledby="cv-awards" data-reveal>
        <SectionTitle title="Awards" />
        <div class="card-base text-sm text-slate-600">
          <p>No awards listed yet. Add your scholarships, honors, and competitions here.</p>
        </div>
      </section>

      <section aria-labelledby="cv-skills" data-reveal>
        <SectionTitle title="Skills" />
        <div class="card-base">
          <ul class="flex flex-wrap gap-2">
            {skills.map((skill) => (
              <li class="rounded-full bg-slate-100 px-3 py-1 text-sm text-slate-700">{skill}</li>
            ))}
          </ul>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
