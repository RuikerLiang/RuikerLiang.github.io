---
import { profile } from '@/data/profile';
---

<section class="section-space">
  <div class="container-page">
    <div class="relative overflow-hidden rounded-2xl border border-slate-200 bg-gradient-to-br from-white via-slate-50 to-accent-50/60 p-6 shadow-soft sm:p-10">
      <div class="pointer-events-none absolute inset-0 opacity-40 [background-image:linear-gradient(to_right,rgba(148,163,184,0.15)_1px,transparent_1px),linear-gradient(to_bottom,rgba(148,163,184,0.12)_1px,transparent_1px)] [background-size:26px_26px]" aria-hidden="true"></div>

      <div class="relative grid gap-8 md:grid-cols-[1.6fr_1fr] md:items-center">
        <div>
          <p class="text-sm font-medium text-accent-700">{profile.affiliation}</p>
          <h1 class="mt-3 text-3xl font-semibold leading-tight tracking-tight text-slate-900 sm:text-5xl">{profile.displayName}</h1>
          <p class="mt-3 text-base font-medium text-slate-700 sm:text-lg">{profile.title}</p>
          <p class="mt-5 max-w-2xl text-sm leading-7 text-slate-600 sm:text-base">{profile.shortTagline}</p>

          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/projects" class="btn-primary">View Projects</a>
            <a href="/contact" class="btn-secondary">Contact Me</a>
          </div>
        </div>

        <div class="mx-auto w-full max-w-xs">
          <div class="card-base flex aspect-square items-center justify-center rounded-2xl border-dashed text-center">
            <div>
              <p class="text-sm font-medium text-slate-500">Profile Photo</p>
              <p class="mt-1 text-xs text-slate-400">Replace with your own image later</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
