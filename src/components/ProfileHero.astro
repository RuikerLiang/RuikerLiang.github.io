---
import { profile, motivation } from '@/data/profile';
---

<section class="section-space">
  <div class="container-page">
    <div class="grid gap-10 border-b border-slate-200 pb-14 xl:grid-cols-[1.45fr_0.95fr] xl:items-start">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.18em] text-slate-500">{profile.affiliation}</p>
        <h1 class="mt-4 text-4xl font-semibold leading-none tracking-tight text-slate-950 sm:text-6xl">{profile.displayName}</h1>
        <p class="mt-4 text-lg font-medium text-slate-800">{profile.title}</p>
        <p class="mt-8 max-w-3xl text-lg leading-9 text-slate-700">{profile.shortTagline}</p>

        <div class="mt-10 grid gap-8 border-t border-slate-200 pt-8 lg:grid-cols-2">
          <section>
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-500">Profile</p>
            <p class="mt-4 text-base leading-8 text-slate-700">{profile.bio}</p>
          </section>

          <section class="lg:border-l lg:border-slate-200 lg:pl-8">
            <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-500">Approach</p>
            <p class="mt-4 text-base leading-8 text-slate-700">{motivation}</p>
          </section>
        </div>
      </div>

      <aside class="xl:border-l xl:border-slate-200 xl:pl-10">
        <div class="aspect-[4/4.2] border border-slate-300 bg-white text-center">
          <div class="flex h-full items-center justify-center">
            <div>
              <p class="text-sm font-medium text-slate-700">Profile Photo</p>
              <p class="mt-1 text-xs text-slate-500">Optional: add your portrait here later</p>
            </div>
          </div>
        </div>

        <div class="mt-8 border-t border-slate-200 pt-8">
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-slate-500">Quick Snapshot</p>
          <dl class="mt-5 space-y-4 text-sm">
            <div class="flex items-start justify-between gap-6 border-b border-slate-200 pb-4">
              <dt class="text-slate-500">Name</dt>
              <dd class="text-right font-medium text-slate-900">{profile.name}</dd>
            </div>
            <div class="flex items-start justify-between gap-6 border-b border-slate-200 pb-4">
              <dt class="text-slate-500">Program</dt>
              <dd class="text-right font-medium text-slate-900">Electrical and Computer Engineering</dd>
            </div>
            <div class="flex items-start justify-between gap-6 border-b border-slate-200 pb-4">
              <dt class="text-slate-500">Cohort</dt>
              <dd class="text-right font-medium text-slate-900">2023</dd>
            </div>
            <div class="flex items-start justify-between gap-6">
              <dt class="text-slate-500">Location</dt>
              <dd class="text-right font-medium text-slate-900">{profile.location}</dd>
            </div>
          </dl>
        </div>
      </aside>
    </div>
  </div>
</section>
