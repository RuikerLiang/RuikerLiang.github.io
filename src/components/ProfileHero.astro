---
import { profile, motivation } from '@/data/profile';

const aboutPillars = [
  {
    title: 'Hands-on Systems',
    summary: 'I like getting close to implementation details and understanding how each layer works together.'
  },
  {
    title: 'End-to-End Ownership',
    summary: 'From development to deployment, I enjoy carrying projects through the full engineering cycle.'
  },
  {
    title: 'Practical Impact',
    summary: 'The work I enjoy most connects strong technical depth with clear real-world usefulness.'
  }
];
---

<section class="section-space">
  <div class="container-page">
    <div class="relative overflow-hidden rounded-[2rem] border border-slate-200 bg-gradient-to-br from-white via-slate-50 to-accent-50/70 p-6 shadow-soft sm:p-10">
      <div
        class="pointer-events-none absolute inset-0 opacity-50 [background-image:radial-gradient(circle_at_top_right,rgba(67,56,202,0.16),transparent_28%),linear-gradient(to_right,rgba(148,163,184,0.15)_1px,transparent_1px),linear-gradient(to_bottom,rgba(148,163,184,0.12)_1px,transparent_1px)] [background-size:auto,26px_26px,26px_26px]"
        aria-hidden="true"
      ></div>

      <div class="relative grid gap-8 xl:grid-cols-[1.45fr_0.95fr] xl:items-start">
        <div>
          <p class="text-sm font-medium text-accent-700">{profile.affiliation}</p>
          <h1 class="mt-3 text-3xl font-semibold leading-tight tracking-tight text-slate-900 sm:text-5xl">{profile.displayName}</h1>
          <p class="mt-3 text-base font-medium text-slate-700 sm:text-lg">{profile.title}</p>
          <p class="mt-5 max-w-2xl text-sm leading-7 text-slate-600 sm:text-base">{profile.shortTagline}</p>

          <div class="mt-6 grid gap-4 lg:grid-cols-2">
            <article class="rounded-2xl border border-white/80 bg-white/85 p-5 shadow-sm backdrop-blur">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-700">Profile</p>
              <p class="mt-3 text-sm leading-7 text-slate-600 sm:text-base">{profile.bio}</p>
            </article>

            <article class="rounded-2xl border border-white/80 bg-white/85 p-5 shadow-sm backdrop-blur">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-accent-700">Approach</p>
              <p class="mt-3 text-sm leading-7 text-slate-600 sm:text-base">{motivation}</p>
            </article>
          </div>

          <ul class="mt-5 flex flex-wrap gap-2" aria-label="Highlights">
            {profile.highlights.map((item) => (
              <li class="rounded-full bg-white/80 px-3 py-1 text-sm font-medium text-slate-700 ring-1 ring-slate-200">{item}</li>
            ))}
          </ul>

          <div class="mt-6 flex flex-wrap gap-3">
            <a href="#projects" class="btn-primary">View Projects</a>
            <a href="#background" class="btn-secondary">See Background</a>
          </div>
        </div>

        <div class="space-y-4">
          <div class="mx-auto w-full max-w-sm">
            <div class="card-base flex aspect-[4/4.2] items-center justify-center rounded-2xl border-dashed text-center">
              <div>
                <p class="text-sm font-medium text-slate-500">Profile Photo</p>
                <p class="mt-1 text-xs text-slate-400">Optional: add your portrait here later</p>
              </div>
            </div>
          </div>

          <div class="rounded-2xl bg-slate-900 p-5 text-slate-50 shadow-soft">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-300">Quick Snapshot</p>
            <dl class="mt-4 space-y-4 text-sm">
              <div class="flex items-start justify-between gap-4 border-b border-slate-800/80 pb-3">
                <dt class="text-slate-400">Name</dt>
                <dd class="text-right font-medium text-white">{profile.name}</dd>
              </div>
              <div class="flex items-start justify-between gap-4 border-b border-slate-800/80 pb-3">
                <dt class="text-slate-400">Program</dt>
                <dd class="text-right font-medium text-white">Electrical and Computer Engineering</dd>
              </div>
              <div class="flex items-start justify-between gap-4 border-b border-slate-800/80 pb-3">
                <dt class="text-slate-400">Cohort</dt>
                <dd class="text-right font-medium text-white">2023</dd>
              </div>
              <div class="flex items-start justify-between gap-4">
                <dt class="text-slate-400">Location</dt>
                <dd class="text-right font-medium text-white">{profile.location}</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>

      <div class="relative mt-6 grid gap-3 md:grid-cols-3">
        {aboutPillars.map((item) => (
          <article class="rounded-2xl border border-white/80 bg-white/85 p-4 shadow-sm backdrop-blur">
            <p class="text-sm font-semibold text-slate-900">{item.title}</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">{item.summary}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
