---
import { profile } from '@/data/profile';
import type { Publication } from '@/data/publications';

interface Props {
  publication: Publication;
}

const { publication } = Astro.props as Props;

const normalizedName = profile.name.toLowerCase();
---

<article class="card-base" data-reveal>
  <h3 class="text-base font-semibold text-slate-900 sm:text-lg">{publication.title}</h3>

  <p class="mt-2 text-sm text-slate-600">
    {
      publication.authors.map((author, index) => {
        const isSelf = author.toLowerCase() === normalizedName;
        return (
          <>
            {index > 0 && <span>, </span>}
            <span class={isSelf ? 'font-semibold text-accent-700' : ''}>{author}</span>
          </>
        );
      })
    }
  </p>

  <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-600">
    <span>{publication.venue}</span>
    <span aria-hidden="true">•</span>
    <span>{publication.year}</span>
    <span aria-hidden="true">•</span>
    <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">{publication.status}</span>
  </div>

  {(publication.links?.paper || publication.links?.code || publication.links?.poster || publication.links?.slides) && (
    <div class="mt-4 flex flex-wrap gap-2">
      {publication.links?.paper && (
        <a href={publication.links.paper} target="_blank" rel="noopener noreferrer" class="btn-secondary">Paper</a>
      )}
      {publication.links?.code && (
        <a href={publication.links.code} target="_blank" rel="noopener noreferrer" class="btn-secondary">Code</a>
      )}
      {publication.links?.poster && (
        <a href={publication.links.poster} target="_blank" rel="noopener noreferrer" class="btn-secondary">Poster</a>
      )}
      {publication.links?.slides && (
        <a href={publication.links.slides} target="_blank" rel="noopener noreferrer" class="btn-secondary">Slides</a>
      )}
    </div>
  )}
</article>
