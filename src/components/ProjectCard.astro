---
import type { Project } from '@/data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props as Props;
---

<article class="border-t border-slate-200 py-8" data-reveal>
  <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
    <h3 class="text-2xl font-semibold tracking-tight text-slate-900">
      {project.links?.demo ? (
        <a href={project.links.demo} target="_blank" rel="noopener noreferrer" class="underline-offset-4 transition hover:underline">
          {project.name}
        </a>
      ) : (
        project.name
      )}
    </h3>
    <span class="shrink-0 text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">{project.period}</span>
  </div>

  <p class="mt-5 max-w-4xl text-base leading-8 text-slate-700">{project.summary}</p>

  <div class="mt-6">
    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">My Contribution</p>
    <p class="mt-3 max-w-4xl text-base leading-8 text-slate-700">{project.contribution}</p>
  </div>

  <div class="mt-6 border-t border-slate-200 pt-4">
    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-500">Technologies</p>
    <p class="mt-3 text-sm leading-7 text-slate-700">{project.technologies.join(' / ')}</p>
  </div>

  {(project.links?.paper || project.links?.code || project.links?.demo) && (
    <div class="mt-6 flex flex-wrap gap-5">
      {project.links?.paper && (
        <a href={project.links.paper} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-slate-900 underline underline-offset-4">Paper</a>
      )}
      {project.links?.code && (
        <a href={project.links.code} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-slate-900 underline underline-offset-4">Code</a>
      )}
      {project.links?.demo && (
        <a href={project.links.demo} target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-slate-900 underline underline-offset-4">Demo</a>
      )}
    </div>
  )}
</article>
