---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about' },
  { label: 'Research', href: '/research' },
  { label: 'Projects', href: '/projects' },
  { label: 'Publications', href: '/publications' },
  { label: 'CV', href: '/cv' },
  { label: 'Contact', href: '/contact' }
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header id="site-header" class="sticky top-0 z-50 border-b border-transparent bg-slate-50/85 backdrop-blur transition-all duration-200">
  <nav class="container-page flex min-h-16 items-center justify-between" aria-label="Primary">
    <a href="/" class="text-sm font-semibold tracking-wide text-slate-900">Kerui Zhang</a>

    <button
      id="menu-toggle"
      class="inline-flex rounded-md border border-slate-300 p-2 text-slate-700 md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle navigation menu"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <ul class="hidden items-center gap-1 md:flex">
      {navItems.map((item) => {
        const normalized = item.href.replace(/\/$/, '') || '/';
        const isActive = currentPath === normalized;

        return (
          <li>
            <a
              href={item.href}
              class:list={[
                'rounded-md px-3 py-2 text-sm font-medium transition',
                isActive ? 'bg-accent-50 text-accent-700' : 'text-slate-600 hover:bg-slate-100 hover:text-slate-900'
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>

  <div id="mobile-menu" class="container-page hidden pb-3 md:hidden">
    <ul class="space-y-1 rounded-lg border border-slate-200 bg-white p-2 shadow-soft">
      {navItems.map((item) => {
        const normalized = item.href.replace(/\/$/, '') || '/';
        const isActive = currentPath === normalized;

        return (
          <li>
            <a
              href={item.href}
              class:list={[
                'block rounded-md px-3 py-2 text-sm font-medium transition',
                isActive ? 'bg-accent-50 text-accent-700' : 'text-slate-700 hover:bg-slate-100'
              ]}
              aria-current={isActive ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const button = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  const onScroll = () => {
    if (!header) return;
    const scrolled = window.scrollY > 10;
    header.classList.toggle('border-slate-200', scrolled);
    header.classList.toggle('shadow-sm', scrolled);
  };

  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  button?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    button.setAttribute('aria-expanded', String(Boolean(isHidden)));
  });
</script>
