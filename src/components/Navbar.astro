---
const navItems = [
  { label: 'Background', href: '#background' },
  { label: 'Projects', href: '#projects' },
  { label: 'Skills', href: '#skills' }
];
---

<header id="site-header" class="sticky top-0 z-50 border-b border-transparent bg-slate-50/85 backdrop-blur transition-all duration-200">
  <nav class="container-page flex min-h-16 items-center justify-between" aria-label="Primary">
    <a href="https://navarhythm.com/" class="text-sm font-semibold tracking-wide text-slate-900 transition hover:text-accent-700">NavaRhythm</a>

    <button
      id="menu-toggle"
      class="inline-flex rounded-md border border-slate-300 p-2 text-slate-700 md:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Toggle navigation menu"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <ul class="hidden items-center gap-1 md:flex">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="rounded-md px-3 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-100 hover:text-slate-900"
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div id="mobile-menu" class="container-page hidden pb-3 md:hidden">
    <ul class="space-y-1 rounded-lg border border-slate-200 bg-white p-2 shadow-soft">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class="block rounded-md px-3 py-2 text-sm font-medium text-slate-700 transition hover:bg-slate-100">
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const button = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  const onScroll = () => {
    if (!header) return;
    const scrolled = window.scrollY > 10;
    header.classList.toggle('border-slate-200', scrolled);
    header.classList.toggle('shadow-sm', scrolled);
  };

  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  button?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden');
    button.setAttribute('aria-expanded', String(Boolean(isHidden)));
  });

  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      button?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
