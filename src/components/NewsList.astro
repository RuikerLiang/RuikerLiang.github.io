---
import type { NewsItem } from '@/data/news';

interface Props {
  items: NewsItem[];
}

const { items } = Astro.props as Props;
---

<div class="card-base" data-reveal>
  <ul class="space-y-4">
    {items.map((item) => (
      <li class="border-l-2 border-accent-200 pl-4">
        <p class="text-xs font-medium uppercase tracking-wide text-accent-700">{item.date}</p>
        <p class="mt-1 text-sm leading-6 text-slate-600">
          {item.link ? (
            <a href={item.link} class="underline-offset-2 hover:text-accent-700 hover:underline">{item.content}</a>
          ) : (
            item.content
          )}
        </p>
      </li>
    ))}
  </ul>
</div>
