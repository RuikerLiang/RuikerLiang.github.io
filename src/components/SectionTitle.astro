---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props as Props;
---

<div class="mb-6">
  <h2 class="text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">{title}</h2>
  {subtitle && <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600 sm:text-base">{subtitle}</p>}
</div>
